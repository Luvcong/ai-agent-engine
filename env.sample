# API prefix
API_V1_PREFIX = "/api/v1"

# CORS allowed origins for local frontend development
CORS_ORIGINS = ["http://localhost:3000", "http://localhost:5173"]

# OpenAI settings
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1

# 공공데이터포털 API settings
PUBLIC_DATA_API_KEY=your_public_data_api_key
PUBLIC_DATA_TIMEOUT=20

# SQLite checkpointer path for thread-based conversation memory
SQLITE_CHECKPOINTER_PATH="app/data/checkpoints.db"

# LangGraph / agent recursion limit
DEEPAGENT_RECURSION_LIMIT=20
