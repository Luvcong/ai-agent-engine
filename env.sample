API_V1_PREFIX = "/api/v1"

# CORS allowed origins for local frontend development
CORS_ORIGINS = ["http://localhost:3000", "http://localhost:5173"]

# OpenAI settings
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1

# 공공데이터포털 API settings
PUBLIC_DATA_API_KEY=your_public_data_api_key
PUBLIC_DATA_TIMEOUT=20
PHARMACY_SEARCH_LIMIT=5

# Elasticsearch settings
ELASTICSEARCH_URL=your_elasticsearch_url
ELASTICSEARCH_USERNAME=your_elasticsearch_username
ELASTICSEARCH_PASSWORD=your_elasticsearch_password
ELASTICSEARCH_INDEX=your_elasticsearch_index
ELASTICSEARCH_TIMEOUT=20
ELASTICSEARCH_DISEASE_SEARCH_LIMIT=5

# SQLite checkpointer path for thread-based conversation memory
SQLITE_CHECKPOINTER_PATH="app/data/checkpoints.db"

# LangGraph / agent recursion limit
DEEPAGENT_RECURSION_LIMIT=20

# Opik tracing settings
# Cloud example:
# OPIK_URL_OVERRIDE=https://www.comet.com/opik/api
# OPIK_API_KEY=your_opik_api_key
# OPIK_WORKSPACE=your_workspace_name
# OPIK_PROJECT_NAME=medical-info-agent
#
# Self-hosted example:
# OPIK_URL_OVERRIDE=http://localhost:5173/api
# OPIK_PROJECT_NAME=medical-info-agent
